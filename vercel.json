{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "entrypoint": "index.js"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/_/backend/api/:path*" }
  ]
}
